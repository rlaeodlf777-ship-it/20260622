# ⚠️ 이 파일은 예시입니다. 실제 값은 .env 에 넣으세요 (.env.example 을 수정하지 마세요)
# Vercel Dashboard → Settings → Environment Variables 에도 동일하게 등록

GEMINI_API_KEY=your_gemini_api_key_here

# Supabase → Project Settings → API (URL에는 /rest/v1 붙이지 마세요)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
